server {
    listen 80;
    listen [::]:80;

    server_name egshop.az www.egshop.az 178.105.240.35;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;

    server_name egshop.az www.egshop.az;
    root /var/www/eg-shop/dist;
    index index.html;

    ssl_certificate /etc/letsencrypt/live/egshop.az/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/egshop.az/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
    ssl_verify_client off;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https:; media-src 'self' https:; connect-src 'self' https://ootloyfutihvupfforrv.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
    add_header Cache-Control "no-cache" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location = /health.txt {
        access_log off;
        try_files $uri =404;
    }

    location /src/ {
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
}
