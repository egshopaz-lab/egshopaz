# The certificate must include egshop.az, www.egshop.az, seller.egshop.az,
# pvz.egshop.az and admin.egshop.az as SAN names.

map $host $egshop_portal_root {
    default             /login;
    seller.egshop.az    /seller;
    pvz.egshop.az       /pvz;
    admin.egshop.az     /login;
}

server {
    listen 80;
    listen [::]:80;
    server_name www.egshop.az;
    return 301 https://egshop.az$request_uri;
}

server {
    listen 80;
    listen [::]:80;
    server_name egshop.az seller.egshop.az pvz.egshop.az admin.egshop.az;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name egshop.az www.egshop.az;

    ssl_certificate /etc/letsencrypt/live/egshop.az/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/egshop.az/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;

    client_max_body_size 10m;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(self), microphone=(), geolocation=(self)" always;

    # Permanent public entry points for the operational portals.
    location = /become-seller { return 302 https://seller.egshop.az/register; }
    location = /seller { return 302 https://seller.egshop.az/seller; }
    location = /pvz { return 302 https://pvz.egshop.az/pvz; }
    location = /admin { return 302 https://admin.egshop.az/dashboard; }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name seller.egshop.az pvz.egshop.az admin.egshop.az;

    ssl_certificate /etc/letsencrypt/live/egshop.az/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/egshop.az/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;

    client_max_body_size 10m;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(self), microphone=(), geolocation=(self)" always;
    add_header X-Robots-Tag "noindex, nofollow" always;

    location = /robots.txt {
        default_type text/plain;
        return 200 "User-agent: *\nDisallow: /\n";
    }

    # Redirect each operational subdomain before the application renders.
    # This prevents the marketplace SSR shell from flashing on portal roots.
    location = / {
        add_header Cache-Control "no-store" always;
        return 302 $egshop_portal_root;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }
}
