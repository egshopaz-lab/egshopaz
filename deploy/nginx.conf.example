server {
    listen 80;
    listen [::]:80;

    server_name egshop.az www.egshop.az 178.105.240.35;
    root /var/www/eg-shop/dist;
    index index.html;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https:; connect-src 'self' https://ootloyfutihvupfforrv.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
    add_header Cache-Control "no-cache" always;

    # Add this inside the HTTPS server block after TLS is configured:
    # add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location = /health.txt {
        access_log off;
        try_files $uri =404;
    }

    location /src/ {
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
}
